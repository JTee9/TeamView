<div class="container mt-5">
  <div class="card">
    <div class="card-body">
      <div class="text-center mb-4">
        <% if @team.logo_url.present? %>
          <%= image_tag @team.logo_url, alt: @team.teamname, style: "height: 120px; width: auto;" %>
        <% end %>
        
        <h2 class="card-title mt-3"><%= @team.teamname %></h2>

        <!-- Fan count -->
  <div class="mt-2">
    <% if @team.fan_count > 0 %>
      <span class="badge bg-danger">
        ❤️ <%= @team.fan_count %> <%= 'fan'.pluralize(@team.fan_count) %>
      </span>
    <% end %>
  </div>

        <div class="mt-3">
          <span class="badge bg-primary">Position: <%= @team.rank %></span>
          <span class="badge bg-success">Points: <%= @team.points %></span>
          <span class="badge bg-info text-dark">Played: <%= @team.played %></span>
        </div>
        
        <div class="mt-2">
          <small class="text-muted">
            Form: <%= render_form(@team.form) %>
          </small>
        </div>
        
        <% if @team.last_updated %>
          <div class="mt-2">
            <small class="text-muted">
              Last updated: <%= time_ago_in_words(@team.last_updated) %> ago
            </small>
          </div>
        <% end %>
      </div>
      
      <hr>
      
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Squad (<%= @team.players.count %> players)</h4>
        <% if user_signed_in? %>
          <%= button_to "🔄 Update Squad", 
                        update_squad_team_path(@team),
                        method: :post,
                        class: "btn btn-sm btn-success",
                        form: { 
                          style: "display: inline-block;",
                          data: { turbo_confirm: "This will use API requests. Continue?" }
                        } %>
        <% end %>
      </div>
      
      <% if @players.any? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th class="text-center">#</th>
                <th>Name</th>
                <th>Position</th>
                <th class="text-center d-none d-md-table-cell">Age</th>
              </tr>
            </thead>
            <tbody>
              <% @players.each do |player| %>
                <tr>
                  <td class="text-center">
                    <% if player.shirt_number %>
                      <span class="badge bg-dark"><%= player.shirt_number %></span>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </td>
                  <td><strong><%= player.name %></strong></td>
                  <td>
                    <span class="badge bg-secondary"><%= player.position %></span>
                  </td>
                  <td class="text-center d-none d-md-table-cell">
                    <%= player.age || '-' %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info">
          No players loaded yet. 
          <% if user_signed_in? %>
            Click "Update Squad" above to fetch player data.
          <% else %>
            Sign in to update player data.
          <% end %>
        </div>
      <% end %>
      
      <%= link_to "← Back to League Table", teams_path, class: "btn btn-secondary mt-4" %>
    </div>
  </div>
</div>