<div class="container mt-4">
  <!-- Header with League Selector and Update button -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1><%= @selected_league %></h1>
      <% if @teams.any? && @teams.first.last_updated %>
        <small class="text-muted">
          Last updated: <%= time_ago_in_words(@teams.first.last_updated) %> ago
        </small>
      <% end %>
    </div>
    
    <div class="d-flex gap-2 align-items-center">
      <!-- League Dropdown -->
      <%= form_with url: teams_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
        <%= f.select :league, 
                     @available_leagues,
                     { selected: @selected_league },
                     { 
                       class: "form-select form-select-sm",
                       style: "width: auto;",
                       onchange: "this.form.submit();"
                     } %>
      <% end %>
      
      <% if user_signed_in? %>
        <%= form_with url: update_standings_teams_path(league: @selected_league), 
                      method: :post,
                      local: true,
                      class: "d-flex gap-2 align-items-center" do |f| %>
          <div class="form-check">
            <%= f.check_box :fetch_squads, class: "form-check-input", id: "fetchSquads" %>
            <%= f.label :fetch_squads, "Include squads", class: "form-check-label small", for: "fetchSquads" %>
          </div>
          <%= f.submit "🔄 Update #{@selected_league}", 
                      class: "btn btn-success btn-sm",
                      data: { 
                        turbo_confirm: "This will fetch data for #{@selected_league}. Continue?"
                      } %>
        <% end %>
        <%= button_to "Sign Out", destroy_user_session_path, 
                      method: :delete,
                      class: "btn btn-outline-secondary btn-sm",
                      form: { style: "display: inline-block;" } %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
      <% end %>
    </div>
  </div>

  <!-- Show user's favorite teams -->
<% if user_signed_in? %>
  <% user_favorite = current_user.favorite_for_league(@selected_league) %>
  <% if user_favorite %>
    <div class="alert alert-info d-flex align-items-center mb-4">
      <% if user_favorite.team.logo_url.present? %>
        <%= image_tag user_favorite.team.logo_url, 
                      style: "height: 30px; width: 30px; object-fit: contain;",
                      class: "me-2" %>
      <% end %>
      <div>
        <strong>Your <%= @selected_league %> team:</strong> 
        <%= link_to user_favorite.team.teamname, team_path(user_favorite.team), class: "alert-link" %>
      </div>
    </div>
  <% else %>
    <div class="alert alert-secondary mb-4">
      <small>Click the 🤍 next to a team to show your support!</small>
    </div>
  <% end %>
<% end %>

  <% if @teams.any? %>
    <!-- League Table -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-dark">
              <tr>
                <th class="text-center" style="width: 50px;">Pos</th>
                <th>Club</th>
                <th class="text-center d-none d-md-table-cell">Played</th>
                <th class="text-center d-none d-md-table-cell">W</th>
                <th class="text-center d-none d-md-table-cell">D</th>
                <th class="text-center d-none d-md-table-cell">L</th>
                <th class="text-center d-none d-lg-table-cell">GF</th>
                <th class="text-center d-none d-lg-table-cell">GA</th>
                <th class="text-center">GD</th>
                <th class="text-center"><strong>Pts</strong></th>
                <th class="text-center d-none d-md-table-cell">Form</th>
              </tr>
            </thead>
            <tbody>
  <% @teams.each do |team| %>
    <% user_favorited = user_signed_in? && current_user.favorited?(team) %>
    <tr class="<%= standings_row_class(team.rank, @selected_league) %>">
      <td class="text-center fw-bold"><%= team.rank %></td>
      <td>
        <div class="d-flex align-items-center justify-content-between">
          <div class="d-flex align-items-center">
            <%= link_to team_path(team), class: "text-decoration-none text-dark d-flex align-items-center" do %>
              <% if team.logo_url.present? %>
                <%= image_tag team.logo_url, 
                              alt: team.teamname, 
                              class: "me-2",
                              style: "height: 25px; width: 25px; object-fit: contain;" %>
              <% end %>
              <span class="fw-semibold"><%= team.teamname %></span>
            <% end %>
          </div>
          
          <!-- Heart Icon with Fan Count -->
<div class="d-flex align-items-center gap-2 ms-3">
  <% if user_signed_in? %>
    <% if user_favorited %>
      <%= button_to unfavorite_team_path(api_football_id: team.api_football_id), 
                    method: :delete,
                    class: "btn btn-link p-0 border-0",
                    style: "text-decoration: none;",
                    form: { style: "display: inline-block;" },
                    title: "Unfavorite" do %>
        <span style="color: #dc3545; font-size: 1.2rem;">❤️</span>
      <% end %>
    <% else %>
      <%= button_to favorite_team_path(api_football_id: team.api_football_id), 
                    method: :post,
                    class: "btn btn-link p-0 border-0",
                    style: "text-decoration: none;",
                    form: { style: "display: inline-block;" },
                    title: "Favorite this team" do %>
        <span style="color: #ccc; font-size: 1.2rem;">🤍</span>
      <% end %>
    <% end %>
  <% else %>
    <span style="color: #ccc; font-size: 1.2rem;" title="Sign in to favorite">🤍</span>
  <% end %>
  
  <% if team.fan_count > 0 %>
    <small class="text-muted"><%= team.fan_count %></small>
  <% end %>
</div>
            
            <% if team.fan_count > 0 %>
              <small class="text-muted"><%= team.fan_count %></small>
            <% end %>
          </div>
        </div>
      </td>
      <td class="text-center d-none d-md-table-cell"><%= team.played %></td>
      <td class="text-center d-none d-md-table-cell"><%= team.wins %></td>
      <td class="text-center d-none d-md-table-cell"><%= team.draws %></td>
      <td class="text-center d-none d-md-table-cell"><%= team.losses %></td>
      <td class="text-center d-none d-lg-table-cell"><%= team.goals_for %></td>
      <td class="text-center d-none d-lg-table-cell"><%= team.goals_against %></td>
      <td class="text-center <%= team.goal_difference >= 0 ? 'text-success' : 'text-danger' %>">
        <%= team.goal_difference >= 0 ? '+' : '' %><%= team.goal_difference %>
      </td>
      <td class="text-center fw-bold"><%= team.points %></td>
      <td class="text-center d-none d-md-table-cell">
        <%= render_form(team.form) %>
      </td>
    </tr>
  <% end %>
</tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Legend (only show for top European leagues) -->
    <% if ['Premier League', 'La Liga', 'Serie A', 'Bundesliga', 'Ligue 1'].include?(@selected_league) %>
      <div class="mt-3">
        <small class="text-muted">
          <span class="badge bg-primary me-2">UEFA Champions League</span>
          <span class="badge bg-info text-dark me-2">UEFA Europa League</span>
          <span class="badge bg-warning text-dark me-2">UEFA Conference League</span>
          <span class="badge bg-danger">Relegation</span>
        </small>
      </div>
    <% end %>
    
    <!-- J-League specific legend -->
    <% if ['J1 League', 'J2 League'].include?(@selected_league) %>
      <div class="mt-3">
        <small class="text-muted">
          <span class="badge bg-primary me-2">AFC Champions League</span>
          <span class="badge bg-info text-dark me-2">Promotion / Playoff</span>
          <span class="badge bg-danger">Relegation</span>
        </small>
      </div>
    <% end %>

  <% else %>
    <div class="alert alert-info">
      <h4>No data for <%= @selected_league %> yet!</h4>
      <% if user_signed_in? %>
        <p>Click the "Update <%= @selected_league %>" button above to fetch data.</p>
      <% else %>
        <p>Sign in to fetch league data.</p>
      <% end %>
    </div>
  <% end %>
</div>

<style>
  .champions-league {
    border-left: 4px solid #0d6efd;
  }
  .europa-league {
    border-left: 4px solid #0dcaf0;
  }
  .conference-league {
    border-left: 4px solid #ffc107;
  }
  .relegation {
    border-left: 4px solid #dc3545;
  }
  .promotion {
    border-left: 4px solid #198754;
  }
  tr:hover {
    background-color: #f8f9fa;
  }
</style>